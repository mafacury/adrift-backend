# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/adrift

# Redis
REDIS_URL=redis://localhost:6379

# Anthropic (moderation)
ANTHROPIC_API_KEY=sk-ant-...

# JWT
JWT_SECRET=change-me-to-a-long-random-string

# Firebase Cloud Messaging
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# Geolocation
# ip-api.com free tier — no key required. Set to "maxmind" to use local DB instead.
GEO_PROVIDER=ip-api

# Boat behaviour
MAX_IGNORES_PER_USER=2
QUEUE_TIMEOUT_MINUTES=10
BOAT_IDLE_DAYS=30
MIN_REPORTS_TO_PAUSE=3

# Moderation
# Number of boats sent before a user is considered "established"
NEW_USER_BOAT_THRESHOLD=5
